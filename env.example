# ─── Postgres ────────────────────────────────────────────────
  POSTGRES_USER=
  POSTGRES_PASSWORD=                
  POSTGRES_DB=t

  # ─── MinIO (S3-compatible local) ─────────────────────────────
  MINIO_ROOT_USER=
  MINIO_ROOT_PASSWORD=

  # ─── App ─────────────────────────────────────────────────────
  # DATABASE_URL (dentro de la red Docker — "postgres" es el hostname del servicio)
  DATABASE_URL=

  # MinIO endpoint y bucket de trabajo
  MINIO_ENDPOINT=
  MINIO_BUCKET=

  # ─── MercadoLibre API ─────────────────────────────────────────
  ML_CLIENT_ID=
  ML_CLIENT_SECRET=