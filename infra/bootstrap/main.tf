# Bootstrap — se corre UNA SOLA VEZ con estado local.
# Crea el bucket S3 y la tabla DynamoDB que el resto de Terraform usará como backend remoto.
#  No podés usar un backend S3 para guardar el estado del recurso que crea ese bucket —
# por eso bootstrap existe separado y usa estado local.

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "tf_state" {
  bucket = "tasajusta-tf-state-966940665955"

  lifecycle {
    prevent_destroy = true
  }
}

resource "aws_s3_bucket_versioning" "tf_state" {
  bucket = aws_s3_bucket.tf_state.id
  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "tf_state" {
  bucket = aws_s3_bucket.tf_state.id
  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

# DynamoDB para el lock del estado — evita que dos terraform apply corran al mismo tiempo
resource "aws_dynamodb_table" "tf_lock" {
  name         = "tasajusta-tf-lock"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "LockID"

  attribute {
    name = "LockID"
    type = "S"
  }
}

output "state_bucket" {
  value = aws_s3_bucket.tf_state.bucket
}

output "lock_table" {
  value = aws_dynamodb_table.tf_lock.name
}
